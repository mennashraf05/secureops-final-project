POSTGRES_DB=secureops_db
POSTGRES_USER=secureops_user
POSTGRES_PASSWORD=change_me

DATABASE_URL=postgresql+psycopg2://secureops_user:change_me@postgres:5432/secureops_db

RABBITMQ_DEFAULT_USER=secureops_user
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq-password
RABBITMQ_USER=secureops_user
RABBITMQ_PASSWORD=change-me-rabbitmq-password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

JWT_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

INTERNAL_API_KEY=change_me
FERNET_KEY=<placeholder-valid-fernet-key-needed>
MASTER_KEY=<placeholder-valid-fernet-key-needed>

FILE_MAX_UPLOAD_MB=10
FILE_ALLOWED_EXTENSIONS=pdf,txt,csv,png,jpg,jpeg,docx,xlsx
FILE_STORAGE_PATH=/app/file-service/storage/vault
FILE_EXPORT_PATH=/app/file-service/export

FRONTEND_PORT=5173
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/auth/oauth/github/callback

TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-telegram-admin-chat-id

AUTH_SEED_ADMIN_NAME=SecureOps Admin
AUTH_SEED_ADMIN_EMAIL=admin@example.com
AUTH_SEED_ADMIN_PASSWORD=change-this-admin-password

EMAIL_DEV_MODE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
SMTP_REDIRECT_TO=
